# SmartCRM Mobile — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Paste the SAME values your web app uses in its .env file. The mobile app
# connects to the same Supabase project, the same RLS policies, the same data.
#
# Expo requires the EXPO_PUBLIC_ prefix for any var that should reach the
# bundle at runtime. Anything without that prefix is server-only (which we
# don't have in Expo's managed workflow).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJh...
